# gRPC (internal)
GRPC_BIND_HOST=0.0.0.0
GRPC_PORT=50051
GRPC_TARGET=localhost:50051

# REST (external)
REST_BIND_HOST=0.0.0.0
REST_PORT=8080

# PostgreSQL (domain data)
POSTGRES_DSN=postgresql://library:library@localhost:5432/library

# MongoDB (ops / analytics events)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=library_ops

LOG_LEVEL=INFO

# Frontend (browser → REST)
NEXT_PUBLIC_API_BASE=http://localhost:8080

# REST gateway: comma-separated browser origins (CORS)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
