# gRPC (internal)
GRPC_BIND_HOST=0.0.0.0
GRPC_PORT=50051
GRPC_TARGET=localhost:50051

# REST (external)
REST_BIND_HOST=0.0.0.0
REST_PORT=8080
# Per-client requests per rolling minute (0 = disable). Comma-separated exact paths exempt from limit.
REST_RATE_LIMIT_PER_MINUTE=180
REST_RATE_LIMIT_EXEMPT_PATHS=/health,/health/ready
# Only if behind a trusted proxy: use first X-Forwarded-For as the client key for rate limiting
REST_RATE_LIMIT_TRUST_X_FORWARDED=0
# Uvicorn HTTP/1.1 keep-alive idle timeout (seconds)
REST_UVICORN_TIMEOUT_KEEP_ALIVE=75

# PostgreSQL (domain data)
POSTGRES_DSN=postgresql://library:library@localhost:5432/library

# MongoDB (ops / analytics events)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=library_ops

LOG_LEVEL=INFO

# Frontend (browser → REST)
NEXT_PUBLIC_API_BASE=http://localhost:8080

# REST gateway: comma-separated browser origins (CORS)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
