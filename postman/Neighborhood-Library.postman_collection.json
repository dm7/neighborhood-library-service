{
  "info": {
    "_postman_id": "neighborhood-library-rest",
    "name": "Neighborhood Library — REST + gRPC reference",
    "description": "REST gateway smoke tests. For gRPC/Protobuf: import `proto/library/v1/library.proto` in Postman (gRPC request) or follow `postman/gRPC-Protobuf-Postman.txt`.\n\nSeed UUIDs match `db/migrations/002_seed.sql` after `docker compose up`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "bookId", "value": "11111111-1111-1111-1111-111111111101" },
    { "key": "memberId", "value": "22222222-2222-2222-2222-222222222201" },
    { "key": "copyIdAvailable", "value": "33333333-3333-3333-3333-333333333303" },
    { "key": "copyIdOnLoan", "value": "33333333-3333-3333-3333-333333333301" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Liveness probe."
          },
          "response": []
        },
        {
          "name": "GET /health/ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health/ready",
            "description": "Readiness: gRPC Ping, Postgres tables, optional Mongo."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "List books",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/books?limit=20&offset=0"
          },
          "response": []
        },
        {
          "name": "Create book",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"API Test Book\",\n  \"author\": \"Pytest\",\n  \"isbn\": \"\",\n  \"published_year\": 2026\n}"
            },
            "url": "{{baseUrl}}/books"
          },
          "response": []
        },
        {
          "name": "Update book",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"The Left Hand of Darkness\",\n  \"author\": \"Ursula K. Le Guin\",\n  \"isbn\": \"9780441478125\",\n  \"published_year\": 1969\n}"
            },
            "url": "{{baseUrl}}/books/{{bookId}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "List members",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/members?limit=20&offset=0"
          },
          "response": []
        },
        {
          "name": "Create member",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Postman User\",\n  \"email\": \"postman.user.unique@example.local\",\n  \"phone\": \"\"\n}"
            },
            "url": "{{baseUrl}}/members"
          },
          "response": []
        },
        {
          "name": "Update member",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Ada Lovelace\",\n  \"email\": \"ada@example.local\",\n  \"phone\": \"\"\n}"
            },
            "url": "{{baseUrl}}/members/{{memberId}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Lending (REST façade)",
      "item": [
        {
          "name": "Borrow (chatty gRPC inside gateway)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"member_id\": \"{{memberId}}\",\n  \"copy_id\": \"{{copyIdAvailable}}\",\n  \"due_at\": \"2026-12-31T23:59:59+00:00\"\n}"
            },
            "url": "{{baseUrl}}/api/borrow",
            "description": "Uses an **available** copy from seed data. Re-run may return 400/409 if copy is already on loan."
          },
          "response": []
        },
        {
          "name": "Return by copy_id",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"copy_id\": \"{{copyIdOnLoan}}\",\n  \"returned_at\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/return",
            "description": "Resolves open borrow for copy. Seed `copyIdOnLoan` has an open loan; empty returned_at lets server default to now."
          },
          "response": []
        }
      ]
    }
  ]
}
