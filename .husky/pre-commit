#!/usr/bin/env sh
set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
"$ROOT/scripts/git-check-allowed-committer.sh"

# Quick Python syntax check (no venv required)
if command -v python3 >/dev/null 2>&1; then
  python3 -m compileall -q \
    grpc_service/src/neighborhood_library_grpc \
    rest_gateway/src/neighborhood_library_gateway \
    2>/dev/null || true
fi

# Frontend unit tests when dependencies are installed
if [ -d frontend/node_modules ] && [ -f frontend/package.json ]; then
  (cd frontend && npm run test)
fi
